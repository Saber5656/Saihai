{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "ITB_RUNTIME=codex ITB_STATE_ROOT=\"$HOME/.codex/state/itb\" \"$HOME/dev/Agent-Teams-Viewer/organization/runtime/infra-team-bootstrap/hooks/itb-session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ITB_RUNTIME=codex ITB_STATE_ROOT=\"$HOME/.codex/state/itb\" \"$HOME/dev/Agent-Teams-Viewer/organization/runtime/infra-team-bootstrap/hooks/itb-final-response-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
