{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/orchestrator-projection.schema.json",
  "title": "Orchestrator Projection",
  "description": "Redacted output-confirmation projection safe for a main-agent bridge principal.",
  "type": "object",
  "$defs": {
    "principal": {
      "type": "object",
      "required": [
        "principal_type",
        "principal_id",
        "authn_method"
      ],
      "properties": {
        "principal_type": {
          "type": "string"
        },
        "principal_id": {
          "type": "string"
        },
        "authn_method": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "rate_limit": {
      "type": "object",
      "required": [
        "max_failed_attempts",
        "failed_attempts"
      ],
      "properties": {
        "max_failed_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "failed_attempts": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "approval_work": {
      "type": "object",
      "required": [
        "workflow_id",
        "initial_step",
        "permission_mode",
        "step_budget",
        "context_ref_count",
        "context_refs_digest",
        "allowed_paths_digest",
        "denied_ops",
        "provider_adapter"
      ],
      "properties": {
        "workflow_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "initial_step": {
          "type": [
            "string",
            "null"
          ]
        },
        "permission_mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "step_budget": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "context_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "context_refs_digest": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "allowed_paths_digest": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "denied_ops": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provider_adapter": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "classification_provenance": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "source",
        "confidence",
        "evidence_refs",
        "selector_threshold",
        "tie_break"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selector_threshold": {
          "type": "number"
        },
        "tie_break": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "redacted_approval": {
      "type": "object",
      "required": [
        "approval_view_version",
        "source",
        "main_agent_prose_used",
        "human_action_id",
        "rate_limit",
        "what_will_execute",
        "classification_provenance",
        "next_action"
      ],
      "properties": {
        "approval_view_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "main_agent_prose_used": {
          "const": false
        },
        "human_action_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "rate_limit": {
          "$ref": "#/$defs/rate_limit"
        },
        "what_will_execute": {
          "$ref": "#/$defs/approval_work"
        },
        "classification_provenance": {
          "$ref": "#/$defs/classification_provenance"
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "child_thread_summary": {
      "type": "object",
      "required": [
        "action_id",
        "issue_id",
        "repo_full_name",
        "branch_name",
        "child_chat_kind",
        "status",
        "worktree_label",
        "worktree_path_digest",
        "instruction_digest",
        "plan_digest",
        "idempotency_replayed"
      ],
      "properties": {
        "action_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "issue_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "repo_full_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "child_chat_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "create",
            "fork",
            null
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "created",
            "reused",
            "pending",
            null
          ]
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "host_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "pending_worktree_id_digest": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "worktree_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "worktree_path_digest": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "instruction_digest": {
          "type": [
            "string",
            "null"
          ]
        },
        "plan_digest": {
          "type": [
            "string",
            "null"
          ]
        },
        "idempotency_replayed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "decision",
    "projection_version",
    "safe_for_principal",
    "request_id",
    "request_status",
    "next_allowed_bridge_actions",
    "context",
    "redacted_fields",
    "transition_effect"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "decision": {
      "const": "ok"
    },
    "projection_version": {
      "const": "1"
    },
    "safe_for_principal": {
      "$ref": "#/$defs/principal"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "request_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "request_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "orchestrator_decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_allowed_bridge_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "submit_request",
          "read_projection",
          "ack_output"
        ]
      }
    },
    "context": {
      "type": "object",
      "required": [
        "ref_count",
        "ref_labels",
        "refs_digest"
      ],
      "properties": {
        "ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "ref_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "refs_digest": {
          "type": "string",
          "pattern": "^sha256:"
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "anyOf": [
        {
          "$ref": "#/$defs/redacted_approval"
        },
        {
          "type": "null"
        }
      ]
    },
    "child_thread_summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/child_thread_summary"
      }
    },
    "redacted_fields": {
      "type": "array",
      "contains": {
        "const": "user_prompt"
      },
      "items": {
        "type": "string"
      }
    },
    "transition_effect": {
      "const": "none"
    },
    "projection_digest": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "replayed": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
