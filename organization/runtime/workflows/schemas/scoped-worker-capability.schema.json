{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/scoped-worker-capability.schema.json",
  "title": "Scoped Worker Capability",
  "description": "Canonical host-side authority for one bounded CLI worker execution.",
  "type": "object",
  "required": [
    "capability_version",
    "capability_id",
    "task_id",
    "run_id",
    "step_id",
    "work_order_digest",
    "issuance_binding_digest",
    "executor_principal",
    "gateway_principal_digest",
    "worker_backend",
    "worker_execution_plan_digest",
    "repository",
    "worktree",
    "allowed_operations",
    "allowed_paths",
    "allowed_network",
    "allowed_provider",
    "prompt_artifact",
    "issued_at",
    "expires_at",
    "nonce",
    "max_execution_count",
    "capability_digest",
    "signature",
    "execution_state"
  ],
  "properties": {
    "capability_version": { "const": "1" },
    "capability_id": { "type": "string", "pattern": "^cap-[0-9a-f]{24}$" },
    "task_id": { "type": "string" },
    "run_id": { "type": "string" },
    "step_id": { "type": "string" },
    "work_order_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "issuance_binding_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "executor_principal": { "type": "object" },
    "gateway_principal_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "worker_backend": { "type": "object" },
    "worker_execution_plan_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "repository": { "type": "object" },
    "worktree": { "type": "object" },
    "allowed_operations": { "type": "array", "items": { "type": "string" } },
    "allowed_paths": { "const": ["."] },
    "allowed_network": { "const": { "allowed": false } },
    "allowed_provider": { "const": { "allowed": false, "provider_id": null } },
    "prompt_artifact": { "type": "object" },
    "issued_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "nonce": { "type": "string" },
    "max_execution_count": { "const": 1 },
    "capability_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "signature": { "type": "object" },
    "execution_state": { "type": "object" }
  },
  "additionalProperties": false
}
