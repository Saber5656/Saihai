{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-teams-viewer.local/schemas/workflows/workflow-template.schema.json",
  "title": "Workflow Template",
  "description": "Reusable process definition. Process authority lives in the harness, not provider output.",
  "type": "object",
  "required": [
    "workflow_template_version",
    "workflow_id",
    "lifecycle_status",
    "purpose",
    "safety_class",
    "publication_gate",
    "gates",
    "mandatory_gates",
    "initial_step",
    "max_steps",
    "scheduler",
    "result_authority",
    "context_sharing",
    "provider_adapter",
    "output_contracts",
    "steps",
    "terminal_states"
  ],
  "properties": {
    "workflow_template_version": {
      "const": "1"
    },
    "workflow_id": {
      "type": "string"
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "active",
        "proposed",
        "deprecated"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "safety_class": {
      "type": "string",
      "enum": [
        "readonly",
        "standard",
        "policy",
        "security"
      ]
    },
    "publication_gate": {
      "type": "object",
      "required": [
        "supported",
        "required_by_default"
      ],
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "required_by_default": {
          "type": "boolean"
        },
        "required_when": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "required": [
        "entry",
        "exit"
      ],
      "properties": {
        "entry": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "mandatory_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "initial_step": {
      "type": "string"
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1
    },
    "scheduler": {
      "type": "object",
      "required": [
        "mode",
        "state_persistence",
        "lock_policy",
        "concurrency"
      ],
      "properties": {
        "mode": {
          "const": "invocation-drain"
        },
        "state_persistence": {
          "const": "durable_state"
        },
        "lock_policy": {
          "const": "global_advisory_lock"
        },
        "concurrency": {
          "const": 1
        }
      },
      "additionalProperties": false
    },
    "result_authority": {
      "type": "object",
      "required": [
        "canonical",
        "signals_only"
      ],
      "properties": {
        "canonical": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "signals_only": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "context_sharing": {
      "type": "object",
      "required": [
        "shared_run_state",
        "step_local_snapshot",
        "provider_transcript"
      ],
      "properties": {
        "shared_run_state": {
          "type": "string"
        },
        "step_local_snapshot": {
          "type": "string"
        },
        "provider_transcript": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "provider_adapter": {
      "type": "object",
      "required": [
        "capability_schema",
        "allowed_transports",
        "default_transport"
      ],
      "properties": {
        "capability_schema": {
          "type": "string"
        },
        "allowed_transports": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "headless_cli",
              "tmux_interactive",
              "codex_exec"
            ]
          }
        },
        "default_transport": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "output_contracts": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "role",
          "assignment_role",
          "permission_mode",
          "provider_route",
          "input_contract",
          "output_contract",
          "quality_gates",
          "transitions"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "assignment_role": {
            "type": "string"
          },
          "permission_mode": {
            "type": "string",
            "enum": [
              "readonly",
              "edit",
              "full"
            ]
          },
          "provider_route": {
            "type": "object"
          },
          "input_contract": {
            "type": "string"
          },
          "output_contract": {
            "type": "string"
          },
          "context_scope": {
            "type": "object"
          },
          "quality_gates": {
            "type": "array"
          },
          "transitions": {
            "type": "array"
          }
        },
        "additionalProperties": false
      }
    },
    "optional_expansions": {
      "type": "array"
    },
    "terminal_states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
