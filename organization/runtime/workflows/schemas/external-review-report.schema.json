{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/external-review-report.schema.json",
  "title": "External Review Report",
  "description": "Authoritative typed report for single_step_external_review. Provider stdout/transcript is signal only.",
  "type": "object",
  "required": [
    "report_version",
    "report_id",
    "request_id",
    "run_id",
    "workflow_id",
    "step_id",
    "result",
    "summary",
    "provider_evidence",
    "findings",
    "authority"
  ],
  "properties": {
    "report_version": {
      "const": "1"
    },
    "report_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "workflow_id": {
      "const": "single_step_external_review"
    },
    "step_id": {
      "const": "review"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "findings",
        "blocked",
        "invalid"
      ]
    },
    "summary": {
      "type": "string"
    },
    "provider_evidence": {
      "type": "object",
      "required": [
        "provider",
        "provider_adapter_id",
        "intended_model",
        "effective_model",
        "effective_model_policy",
        "model_assurance",
        "request_id",
        "provider_session_id",
        "transcript_path",
        "evidence_path"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "provider_adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "intended_model": {
          "type": "string"
        },
        "effective_model": {
          "type": "string"
        },
        "effective_model_policy": {
          "enum": [
            "required_exact_match",
            "record_without_equality"
          ]
        },
        "model_assurance": {
          "enum": [
            "exact_match_enforced",
            "provider_reported_only"
          ]
        },
        "request_id": {
          "type": "string"
        },
        "provider_session_id": {
          "type": "string"
        },
        "transcript_path": {
          "type": "string"
        },
        "evidence_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "severity",
          "status",
          "summary",
          "evidence_refs"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "waived",
              "informational"
            ]
          },
          "summary": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "canonical_result",
        "stdout_is_signal_only",
        "raw_transcript_shared"
      ],
      "properties": {
        "canonical_result": {
          "const": "typed_report_file"
        },
        "stdout_is_signal_only": {
          "const": true
        },
        "raw_transcript_shared": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "result": {
            "const": "findings"
          }
        },
        "required": [
          "result"
        ]
      },
      "then": {
        "properties": {
          "findings": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
