{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/workflow-run.schema.json",
  "title": "Workflow Run State",
  "description": "Durable per-task execution instance. Queue messages are step artifacts under this run.",
  "type": "object",
  "required": [
    "run_version",
    "run_id",
    "task_id",
    "request_id",
    "workflow_id",
    "goal_state",
    "run_state",
    "current_step",
    "iteration",
    "max_steps",
    "step_history",
    "activation",
    "terminal",
    "requester",
    "scheduling",
    "context_sharing",
    "approved_provider_binding"
  ],
  "properties": {
    "run_version": {
      "const": "1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "workflow_id": {
      "type": "string"
    },
    "approved_provider_binding": {
      "type": "object",
      "required": [
        "provider_adapter_id",
        "default_model",
        "effective_model_policy"
      ],
      "properties": {
        "provider_adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "default_model": {
          "type": "string",
          "minLength": 1
        },
        "effective_model_policy": {
          "type": "string",
          "enum": [
            "required_exact_match",
            "record_without_equality"
          ]
        }
      },
      "additionalProperties": false
    },
    "goal_state": {
      "type": "string",
      "enum": [
        "approved",
        "active",
        "blocked",
        "complete",
        "aborted"
      ]
    },
    "run_state": {
      "type": "string",
      "enum": [
        "created",
        "step_queued",
        "waiting_provider",
        "validating",
        "remediating",
        "waiting_human",
        "complete",
        "failed",
        "aborted"
      ]
    },
    "current_step": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1
    },
    "step_history": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "activation": {
      "type": "object",
      "required": [
        "activation_version",
        "activation_source",
        "activation_status",
        "approved_by",
        "approved_at",
        "workflow_selection",
        "classification_provenance",
        "context_scope",
        "activation_scope",
        "next_action"
      ],
      "properties": {
        "activation_version": {
          "const": "1"
        },
        "activation_source": {
          "type": "string",
          "enum": [
            "orchestrator-start",
            "human_ui",
            "manual_cli"
          ]
        },
        "activation_status": {
          "const": "approved"
        },
        "approved_by": {
          "type": "string",
          "enum": [
            "human_explicit_skill_invocation",
            "human_ui_action",
            "manual_operator"
          ]
        },
        "approved_at": {
          "type": "string"
        },
        "workflow_selection": {
          "type": "object",
          "required": [
            "status",
            "workflow_id",
            "initial_step",
            "safety_class",
            "required_safety_class",
            "publication_gate_required",
            "required_gates"
          ],
          "properties": {
            "status": {
              "const": "selected"
            },
            "workflow_id": {
              "type": "string"
            },
            "initial_step": {
              "type": "string"
            },
            "optional_expansions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "safety_class": {
              "type": "string",
              "enum": [
                "readonly",
                "standard",
                "policy",
                "security"
              ]
            },
            "required_safety_class": {
              "type": "string",
              "enum": [
                "readonly",
                "standard",
                "policy",
                "security"
              ]
            },
            "publication_gate_required": {
              "type": "boolean"
            },
            "required_gates": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "classification_provenance": {
          "type": "object",
          "required": [
            "source",
            "confidence",
            "evidence_refs",
            "selector_threshold",
            "tie_break"
          ],
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "human_supplied",
                "deterministic_fixture",
                "bounded_classifier_step"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0.85,
              "maximum": 1
            },
            "evidence_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "selector_threshold": {
              "const": 0.85
            },
            "tie_break": {
              "const": "deterministic_status_order:selected_waiting_human_blocked"
            }
          },
          "additionalProperties": false
        },
        "context_scope": {
          "type": "object",
          "required": [
            "mode",
            "refs",
            "raw_transcript_sharing"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "bounded_refs",
                "refs_only",
                "selected_snapshot",
                "diff_summary"
              ]
            },
            "refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "raw_transcript_sharing": {
              "const": "forbidden"
            }
          },
          "additionalProperties": false
        },
        "activation_scope": {
          "type": "object",
          "required": [
            "allowed_paths",
            "allowed_ops",
            "step_budget",
            "expires_at"
          ],
          "properties": {
            "allowed_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowed_ops": {
              "type": "object",
              "required": [
                "edit",
                "commit",
                "push",
                "network"
              ],
              "properties": {
                "edit": {
                  "type": "boolean"
                },
                "commit": {
                  "type": "boolean"
                },
                "push": {
                  "type": "boolean"
                },
                "network": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "step_budget": {
              "type": "integer",
              "minimum": 1
            },
            "expires_at": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "next_action": {
          "const": "create_workflow_run"
        }
      },
      "additionalProperties": false
    },
    "terminal": {
      "type": "object",
      "required": [
        "status",
        "reason"
      ],
      "properties": {
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "requester": {
      "type": "object"
    },
    "scheduling": {
      "type": "object",
      "required": [
        "scheduler_mode",
        "concurrency_group",
        "state_persistence",
        "lock_policy",
        "concurrency",
        "resume_policy"
      ],
      "properties": {
        "scheduler_mode": {
          "const": "invocation-drain"
        },
        "concurrency_group": {
          "const": "global"
        },
        "state_persistence": {
          "const": "durable_state"
        },
        "lock_policy": {
          "const": "global_advisory_lock"
        },
        "concurrency": {
          "const": 1
        },
        "resume_policy": {
          "type": "string",
          "enum": [
            "manual",
            "daemon_future"
          ]
        }
      },
      "additionalProperties": false
    },
    "context_sharing": {
      "type": "object",
      "required": [
        "shared_run_state",
        "step_local_snapshot",
        "provider_transcript"
      ],
      "properties": {
        "shared_run_state": {
          "const": "typed_durable_state"
        },
        "step_local_snapshot": {
          "const": "immutable_step_attempt_snapshot"
        },
        "provider_transcript": {
          "const": "confined_evidence_path_only"
        }
      },
      "additionalProperties": false
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "provider_execution": {
      "type": "object",
      "required": [
        "execution_version", "step_id", "adapter_id", "provider_binding", "work_order_digest",
        "adapter_request_digest", "context_snapshot_digest", "phase",
        "attempt_number", "attempt_id", "timeout_seconds", "lease", "retry", "last_outcome"
      ],
      "properties": {
        "execution_version": { "const": "1" },
        "step_id": { "type": "string", "minLength": 1 },
        "adapter_id": { "type": "string", "minLength": 1 },
        "provider_binding": {
          "type": "object",
          "required": ["provider_adapter_id", "intended_model", "effective_model_policy"],
          "properties": {
            "provider_adapter_id": { "type": "string", "minLength": 1 },
            "intended_model": { "type": "string", "minLength": 1 },
            "effective_model_policy": {
              "enum": ["required_exact_match", "record_without_equality"]
            }
          },
          "additionalProperties": false
        },
        "work_order_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "adapter_request_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "context_snapshot_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "phase": {
          "enum": ["claimed", "invoking", "result_ready", "retry_scheduled", "human_gate", "completed", "abandoned"]
        },
        "attempt_number": { "type": "integer", "minimum": 1 },
        "attempt_id": { "type": "string", "minLength": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "lease": {
          "type": "object",
          "required": ["lease_id", "claimed_by", "claimed_at", "last_heartbeat_at", "lease_expires_at"],
          "properties": {
            "lease_id": { "type": "string", "minLength": 1 },
            "claimed_by": { "type": "object" },
            "claimed_at": { "type": "string", "minLength": 1 },
            "last_heartbeat_at": { "type": "string", "minLength": 1 },
            "lease_expires_at": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "retry": {
          "type": "object",
          "required": ["last_failure_fingerprint", "consecutive_failures", "auto_retries_used", "max_auto_retries"],
          "properties": {
            "last_failure_fingerprint": { "type": ["string", "null"] },
            "consecutive_failures": { "type": "integer", "minimum": 0 },
            "auto_retries_used": { "type": "integer", "minimum": 0 },
            "max_auto_retries": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "last_outcome": { "type": ["object", "null"] }
      },
      "additionalProperties": false
    },
    "transition_provenance": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "completion_verification": {
      "type": "object",
      "required": [
        "verified_at",
        "decision",
        "report_sha256",
        "evidence_sha256",
        "provider_adapter_id",
        "intended_model",
        "effective_model_policy",
        "model_assurance",
        "verifier"
      ],
      "properties": {
        "verified_at": {
          "type": "string"
        },
        "decision": {
          "const": "complete"
        },
        "report_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "evidence_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "provider_adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "intended_model": {
          "type": "string",
          "minLength": 1
        },
        "effective_model_policy": {
          "enum": ["required_exact_match", "record_without_equality"]
        },
        "model_assurance": {
          "enum": ["exact_match_enforced", "provider_reported_only"]
        },
        "verifier": {
          "type": "object",
          "required": [
            "principal_type",
            "principal_id",
            "authn_method"
          ],
          "properties": {
            "principal_type": {
              "type": "string"
            },
            "principal_id": {
              "type": "string"
            },
            "authn_method": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
