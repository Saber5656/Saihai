{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-teams-viewer.local/schemas/workflows/workflow-run.schema.json",
  "title": "Workflow Run State",
  "description": "Durable per-task execution instance. Queue messages are step artifacts under this run.",
  "type": "object",
  "required": [
    "run_version",
    "run_id",
    "task_id",
    "request_id",
    "workflow_id",
    "goal_state",
    "run_state",
    "current_step",
    "iteration",
    "max_steps",
    "step_history",
    "activation",
    "terminal",
    "requester",
    "scheduling",
    "context_sharing"
  ],
  "properties": {
    "run_version": {
      "const": "1"
    },
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "goal_state": {
      "type": "string",
      "enum": [
        "approved",
        "active",
        "blocked",
        "complete",
        "aborted"
      ]
    },
    "run_state": {
      "type": "string",
      "enum": [
        "created",
        "step_queued",
        "waiting_provider",
        "validating",
        "remediating",
        "waiting_human",
        "complete",
        "failed",
        "aborted"
      ]
    },
    "current_step": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1
    },
    "step_history": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "activation": {
      "type": "object",
      "required": [
        "activation_version",
        "activation_source",
        "activation_status",
        "approved_by",
        "approved_at",
        "workflow_selection",
        "context_scope",
        "activation_scope",
        "next_action"
      ],
      "properties": {
        "activation_version": {
          "const": "1"
        },
        "activation_source": {
          "type": "string",
          "enum": [
            "orchestrator-start",
            "human_ui",
            "manual_cli"
          ]
        },
        "activation_status": {
          "const": "approved"
        },
        "approved_by": {
          "type": "string",
          "enum": [
            "human_explicit_skill_invocation",
            "human_ui_action",
            "manual_operator"
          ]
        },
        "approved_at": {
          "type": "string"
        },
        "workflow_selection": {
          "type": "object",
          "required": [
            "status",
            "workflow_id",
            "initial_step",
            "safety_class",
            "required_safety_class",
            "publication_gate_required",
            "required_gates"
          ],
          "properties": {
            "status": {
              "const": "selected"
            },
            "workflow_id": {
              "type": "string"
            },
            "initial_step": {
              "type": "string"
            },
            "optional_expansions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "safety_class": {
              "type": "string",
              "enum": [
                "readonly",
                "standard",
                "policy",
                "security"
              ]
            },
            "required_safety_class": {
              "type": "string",
              "enum": [
                "readonly",
                "standard",
                "policy",
                "security"
              ]
            },
            "publication_gate_required": {
              "type": "boolean"
            },
            "required_gates": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "context_scope": {
          "type": "object",
          "required": [
            "mode",
            "refs",
            "raw_transcript_sharing"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "bounded_refs",
                "refs_only",
                "selected_snapshot",
                "diff_summary"
              ]
            },
            "refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "raw_transcript_sharing": {
              "const": "forbidden"
            }
          },
          "additionalProperties": false
        },
        "activation_scope": {
          "type": "object",
          "required": [
            "allowed_paths",
            "allowed_ops",
            "step_budget",
            "expires_at"
          ],
          "properties": {
            "allowed_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowed_ops": {
              "type": "object",
              "required": [
                "edit",
                "commit",
                "push",
                "network"
              ],
              "properties": {
                "edit": {
                  "type": "boolean"
                },
                "commit": {
                  "type": "boolean"
                },
                "push": {
                  "type": "boolean"
                },
                "network": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "step_budget": {
              "type": "integer",
              "minimum": 1
            },
            "expires_at": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "next_action": {
          "const": "create_workflow_run"
        }
      },
      "additionalProperties": false
    },
    "terminal": {
      "type": "object",
      "required": [
        "status",
        "reason"
      ],
      "properties": {
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "requester": {
      "type": "object"
    },
    "scheduling": {
      "type": "object",
      "required": [
        "scheduler_mode",
        "concurrency_group",
        "state_persistence",
        "lock_policy",
        "concurrency",
        "resume_policy"
      ],
      "properties": {
        "scheduler_mode": {
          "const": "invocation-drain"
        },
        "concurrency_group": {
          "const": "global"
        },
        "state_persistence": {
          "const": "durable_state"
        },
        "lock_policy": {
          "const": "global_advisory_lock"
        },
        "concurrency": {
          "const": 1
        },
        "resume_policy": {
          "type": "string",
          "enum": [
            "manual",
            "daemon_future"
          ]
        }
      },
      "additionalProperties": false
    },
    "context_sharing": {
      "type": "object",
      "required": [
        "shared_run_state",
        "step_local_snapshot",
        "provider_transcript"
      ],
      "properties": {
        "shared_run_state": {
          "const": "typed_durable_state"
        },
        "step_local_snapshot": {
          "const": "immutable_step_attempt_snapshot"
        },
        "provider_transcript": {
          "const": "confined_evidence_path_only"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
