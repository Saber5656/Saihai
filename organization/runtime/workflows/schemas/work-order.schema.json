{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/work-order.schema.json",
  "title": "Work Order",
  "description": "Bounded request from a front door to the harness runner for one workflow step.",
  "type": "object",
  "required": [
    "work_order_version",
    "task_id",
    "request_id",
    "run_id",
    "workflow_id",
    "step_id",
    "from_role",
    "to_role",
    "assignment_role",
    "instruction",
    "expected_output",
    "context_refs",
    "context_scope",
    "permission_mode",
    "external_provider_allowed",
    "report_path",
    "policy_digest",
    "requester",
    "activation_scope",
    "work_order_authority"
  ],
  "properties": {
    "work_order_version": {
      "const": "1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "workflow_id": {
      "type": "string"
    },
    "step_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "from_role": {
      "type": "string"
    },
    "to_role": {
      "type": "string"
    },
    "assignment_role": {
      "type": "string",
      "enum": [
        "implementer",
        "reviewer",
        "qa",
        "approver",
        "observer",
        "publisher"
      ]
    },
    "instruction": {
      "type": "string"
    },
    "expected_output": {
      "type": "string"
    },
    "context_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "context_scope": {
      "type": "object",
      "required": [
        "mode",
        "raw_transcript_sharing"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "refs_only",
            "selected_snapshot",
            "diff_summary"
          ]
        },
        "raw_transcript_sharing": {
          "const": "forbidden"
        },
        "context_mode_downgraded_from": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "permission_mode": {
      "type": "string",
      "enum": [
        "readonly",
        "edit",
        "full"
      ]
    },
    "external_provider_allowed": {
      "type": "boolean"
    },
    "max_budget_usd": {
      "type": "string"
    },
    "report_path": {
      "type": "string"
    },
    "policy_digest": {
      "type": "string"
    },
    "requester": {
      "type": "object",
      "required": [
        "frontdoor"
      ],
      "properties": {
        "frontdoor": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "manual"
          ]
        },
        "chat_session_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "activation_scope": {
      "type": "object",
      "required": [
        "allowed_paths",
        "allowed_ops",
        "step_budget",
        "expires_at"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_ops": {
          "type": "object",
          "required": [
            "edit",
            "commit",
            "push",
            "network"
          ],
          "properties": {
            "edit": {
              "type": "boolean"
            },
            "commit": {
              "type": "boolean"
            },
            "push": {
              "type": "boolean"
            },
            "network": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "step_budget": {
          "type": "integer",
          "minimum": 1
        },
        "expires_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "work_order_authority": {
      "type": "object",
      "required": [
        "issuer_principal",
        "signature",
        "runner_claim"
      ],
      "properties": {
        "issuer_principal": {
          "type": "object"
        },
        "signature": {
          "type": "object",
          "required": [
            "algorithm",
            "signature",
            "signed_at"
          ],
          "properties": {
            "algorithm": {
              "const": "sha256-local-principal-key"
            },
            "signature": {
              "type": "string",
              "pattern": "^sha256:"
            },
            "signed_at": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "runner_claim": {
          "type": "object",
          "required": [
            "claim_state",
            "lease_expires_at"
          ],
          "properties": {
            "claim_state": {
              "type": "string",
              "enum": [
                "unclaimed",
                "claimed"
              ]
            },
            "lease_id": {
              "type": "string"
            },
            "claimed_by": {
              "type": "object"
            },
            "lease_expires_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "claim_signature": {
              "type": "object"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "worker_execution_plan": {
      "type": "object",
      "required": ["plan_version", "repository", "worktree", "worker_backend"],
      "properties": {
        "plan_version": { "const": "1" },
        "repository": { "type": "object" },
        "worktree": { "type": "object" },
        "worker_backend": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": [
          "workflow_id",
          "step_id"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "workflow_id": { "const": "single_step_external_review" },
              "step_id": { "const": "review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "external_review_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": true },
              "activation_scope": {
                "properties": {
                  "step_budget": { "const": 1 },
                  "allowed_ops": {
                    "properties": {
                      "edit": { "const": false },
                      "commit": { "const": false },
                      "push": { "const": false },
                      "network": { "const": false }
                    }
                  }
                }
              }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "research_only" },
              "step_id": { "const": "research" },
              "assignment_role": { "const": "observer" },
              "expected_output": { "const": "research_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "implement" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "qa" },
              "assignment_role": { "const": "qa" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "implement" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "qa" },
              "assignment_role": { "const": "qa" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "publication_gate" },
              "assignment_role": { "const": "publisher" },
              "expected_output": { "const": "publication_result" },
              "permission_mode": { "const": "full" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "policy_or_permission_change" },
              "step_id": { "const": "policy_review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "policy_or_permission_change" },
              "step_id": { "const": "apply_policy_change" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "policy_or_permission_change" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "security_review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "security_review_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "policy_review" },
              "assignment_role": { "const": "approver" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "implement" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "qa" },
              "assignment_role": { "const": "qa" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "final_security_review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "security_review_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "publication_gate" },
              "assignment_role": { "const": "publisher" },
              "expected_output": { "const": "publication_result" },
              "permission_mode": { "const": "full" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          }
        ]
      }
    }
  ]
}
