{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/work-order.schema.json",
  "title": "Work Order",
  "description": "Bounded request from a front door to the harness runner for one workflow step.",
  "type": "object",
  "required": [
    "work_order_version",
    "task_id",
    "request_id",
    "run_id",
    "workflow_id",
    "step_id",
    "from_role",
    "to_role",
    "assignment_role",
    "instruction",
    "expected_output",
    "context_refs",
    "context_scope",
    "permission_mode",
    "external_provider_allowed",
    "provider_adapter_id",
    "intended_model",
    "effective_model_policy",
    "report_path",
    "policy_digest",
    "requester",
    "activation_scope",
    "work_order_authority"
  ],
  "properties": {
    "work_order_version": {
      "const": "1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "workflow_id": {
      "type": "string"
    },
    "step_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "from_role": {
      "type": "string"
    },
    "to_role": {
      "type": "string"
    },
    "assignment_role": {
      "type": "string",
      "enum": [
        "implementer",
        "reviewer",
        "qa",
        "approver",
        "observer",
        "publisher"
      ]
    },
    "instruction": {
      "type": "string"
    },
    "expected_output": {
      "type": "string"
    },
    "context_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "context_scope": {
      "type": "object",
      "required": [
        "mode",
        "raw_transcript_sharing"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "refs_only",
            "selected_snapshot",
            "diff_summary"
          ]
        },
        "raw_transcript_sharing": {
          "const": "forbidden"
        },
        "context_mode_downgraded_from": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "permission_mode": {
      "type": "string",
      "enum": [
        "readonly",
        "edit",
        "full"
      ]
    },
    "external_provider_allowed": {
      "type": "boolean"
    },
    "provider_adapter_id": {
      "type": "string",
      "minLength": 1
    },
    "intended_model": {
      "type": "string",
      "minLength": 1
    },
    "effective_model_policy": {
      "type": "string",
      "enum": [
        "required_exact_match",
        "record_without_equality"
      ]
    },
    "max_budget_usd": {
      "type": "string"
    },
    "report_path": {
      "type": "string"
    },
    "policy_digest": {
      "type": "string"
    },
    "requester": {
      "type": "object",
      "required": [
        "frontdoor"
      ],
      "properties": {
        "frontdoor": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "cursor",
            "grok",
            "manual"
          ]
        },
        "chat_session_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "frontend_request_binding": {
      "type": "object",
      "required": [
        "owner_principal",
        "checkout_identity_digest"
      ],
      "properties": {
        "owner_principal": {
          "type": "object",
          "required": [
            "principal_type",
            "principal_id",
            "authn_method"
          ],
          "properties": {
            "principal_type": { "const": "main_agent_bridge" },
            "principal_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
            },
            "authn_method": { "const": "installed_frontend_profile" }
          },
          "additionalProperties": false
        },
        "checkout_identity_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "projection_binding": {
      "$ref": "#/$defs/projectionBinding"
    },
    "frontend_launch_session_binding": {
      "type": "object",
      "required": [
        "launch_session_identity",
        "launch_session_digest"
      ],
      "properties": {
        "launch_session_identity": { "$ref": "#/$defs/launchSessionIdentity" },
        "launch_session_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "activation_scope": {
      "type": "object",
      "required": [
        "allowed_paths",
        "allowed_ops",
        "step_budget",
        "expires_at"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_ops": {
          "type": "object",
          "required": [
            "edit",
            "commit",
            "push",
            "network"
          ],
          "properties": {
            "edit": {
              "type": "boolean"
            },
            "commit": {
              "type": "boolean"
            },
            "push": {
              "type": "boolean"
            },
            "network": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "step_budget": {
          "type": "integer",
          "minimum": 1
        },
        "expires_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "work_order_authority": {
      "type": "object",
      "required": [
        "issuer_principal",
        "signature",
        "runner_claim"
      ],
      "properties": {
        "issuer_principal": {
          "type": "object"
        },
        "signature": {
          "type": "object",
          "required": [
            "algorithm",
            "signature",
            "signed_at"
          ],
          "properties": {
            "algorithm": {
              "enum": [
                "sha256-local-principal-key",
                "sha256-hmac-sha256-local-principal-key"
              ]
            },
            "signature": {
              "type": "string",
              "pattern": "^sha256:"
            },
            "signed_at": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "runner_claim": {
          "type": "object",
          "required": [
            "claim_state",
            "lease_expires_at"
          ],
          "properties": {
            "claim_state": {
              "type": "string",
              "enum": [
                "unclaimed",
                "claimed"
              ]
            },
            "lease_id": {
              "type": "string"
            },
            "claimed_by": {
              "type": "object"
            },
            "lease_expires_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "claim_signature": {
              "type": "object"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "worker_execution_plan": {
      "$ref": "#/$defs/workerExecutionPlan"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "workerRuntimeBinding": {
      "type": "object",
      "required": [
        "binding_version", "runtime_realpath", "runtime_digest", "profile_mode",
        "profile_realpath", "profile_digest", "codex_home_realpath", "environment",
        "environment_digest", "argv_template", "argv_digest", "runner_profile_digest"
      ],
      "properties": {
        "binding_version": { "const": "1" },
        "runtime_realpath": { "type": "string", "pattern": "^/" },
        "runtime_digest": { "$ref": "#/$defs/sha256" },
        "profile_mode": { "const": "ignored_by_fixed_argv" },
        "profile_realpath": { "type": "null" },
        "profile_digest": { "$ref": "#/$defs/sha256" },
        "codex_home_realpath": { "type": "string", "pattern": "^/" },
        "environment": {
          "type": "object",
          "required": ["PATH", "HOME", "CODEX_HOME", "LANG", "LC_ALL", "TMPDIR"],
          "properties": {
            "PATH": { "const": "/usr/bin:/bin" },
            "HOME": { "type": "string", "pattern": "^/" },
            "CODEX_HOME": { "type": "string", "pattern": "^/" },
            "LANG": { "const": "C" },
            "LC_ALL": { "const": "C" },
            "TMPDIR": { "const": "/tmp" }
          },
          "additionalProperties": false
        },
        "environment_digest": { "$ref": "#/$defs/sha256" },
        "argv_template": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "argv_digest": { "$ref": "#/$defs/sha256" },
        "runner_profile_digest": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "workerBackend": {
      "type": "object",
      "required": [
        "backend_id", "adapter_version", "executable_path", "executable_digest",
        "runner_profile_digest", "provider_id", "runtime_binding"
      ],
      "properties": {
        "backend_id": { "const": "codex_cli" },
        "adapter_version": { "const": "1" },
        "executable_path": { "type": "string", "pattern": "^/" },
        "executable_digest": { "$ref": "#/$defs/sha256" },
        "runner_profile_digest": { "$ref": "#/$defs/sha256" },
        "provider_id": { "const": "openai-codex" },
        "runtime_binding": { "$ref": "#/$defs/workerRuntimeBinding" }
      },
      "additionalProperties": false
    },
    "projectionBinding": {
      "type": "object",
      "required": [
        "request_id", "task_id", "owner_principal_digest", "checkout_identity_digest"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
        },
        "owner_principal_digest": { "$ref": "#/$defs/sha256" },
        "checkout_identity_digest": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "workerExecutionPlan": {
      "type": "object",
      "required": [
        "plan_version", "projection_binding", "repository", "worktree", "worker_backend"
      ],
      "properties": {
        "plan_version": { "const": "1" },
        "projection_binding": { "$ref": "#/$defs/projectionBinding" },
        "repository": {
          "type": "object",
          "required": ["repo_full_name", "repo_root", "git_common_dir_digest", "base_revision"],
          "properties": {
            "repo_full_name": { "type": "string" },
            "repo_root": { "type": "string", "pattern": "^/" },
            "git_common_dir_digest": { "$ref": "#/$defs/sha256" },
            "base_revision": { "type": "string" }
          },
          "additionalProperties": false
        },
        "worktree": {
          "type": "object",
          "required": ["worktree_key", "branch", "scope"],
          "properties": {
            "worktree_key": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$" },
            "branch": { "type": "string", "pattern": "^codex/scoped-[A-Za-z0-9_.-]+$" },
            "scope": { "const": "whole_task_worktree" }
          },
          "additionalProperties": false
        },
        "worker_backend": { "$ref": "#/$defs/workerBackend" }
      },
      "additionalProperties": false
    },
    "launchSessionIdentity": {
      "type": "object",
      "required": [
        "launch_session_version", "session_id", "deployment_id", "profile_id",
        "principal_id", "workspace_id", "subject_pid", "process_start_token",
        "native_realpath", "native_digest", "profile_realpath", "profile_digest",
        "launch_argv_digest", "checkout_realpath", "checkout_identity_digest",
        "issued_at", "valid_until", "status", "session_kind",
        "commissioning_launch_reference", "commissioning_launch_digest", "supervisor_pid",
        "supervisor_start_token", "record_reference", "record_digest"
      ],
      "properties": {
        "launch_session_version": { "const": "2" },
        "session_id": { "type": "string" },
        "deployment_id": { "type": "string" },
        "profile_id": { "type": "string" },
        "principal_id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "subject_pid": { "type": "integer", "minimum": 1 },
        "process_start_token": { "type": "string", "pattern": "^proc-[0-9a-f]{64}$" },
        "native_realpath": { "type": "string" },
        "native_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "profile_realpath": { "type": "string" },
        "profile_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "launch_argv_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "checkout_realpath": { "type": "string" },
        "checkout_identity_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "issued_at": { "type": "string" },
        "valid_until": { "type": "string" },
        "status": { "const": "active" },
        "session_kind": { "enum": ["standard", "commissioning"] },
        "commissioning_launch_reference": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^commissioning-launches/[A-Za-z0-9_.-]+\\.json$" }
          ]
        },
        "commissioning_launch_digest": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/sha256" }
          ]
        },
        "supervisor_pid": { "type": "integer", "minimum": 1 },
        "supervisor_start_token": { "type": "string", "pattern": "^proc-[0-9a-f]{64}$" },
        "record_reference": { "type": "string", "pattern": "^launch-sessions/[A-Za-z0-9_.-]+\\.json$" },
        "record_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "session_kind": { "const": "standard" } } },
          "then": {
            "properties": {
              "commissioning_launch_reference": { "type": "null" },
              "commissioning_launch_digest": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "session_kind": { "const": "commissioning" } } },
          "then": {
            "properties": {
              "commissioning_launch_reference": { "type": "string", "pattern": "^commissioning-launches/[A-Za-z0-9_.-]+\\.json$" },
              "commissioning_launch_digest": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "workflow_id",
          "step_id"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "workflow_id": { "const": "single_step_external_review" },
              "step_id": { "const": "review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "external_review_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": true },
              "activation_scope": {
                "properties": {
                  "step_budget": { "const": 1 },
                  "allowed_ops": {
                    "properties": {
                      "edit": { "const": false },
                      "commit": { "const": false },
                      "push": { "const": false },
                      "network": { "const": false }
                    }
                  }
                }
              }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "research_only" },
              "step_id": { "const": "research" },
              "assignment_role": { "const": "observer" },
              "expected_output": { "const": "research_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "implement" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "qa" },
              "assignment_role": { "const": "qa" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "standard_code_change" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "implement" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "qa" },
              "assignment_role": { "const": "qa" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "publication_gate" },
              "assignment_role": { "const": "publisher" },
              "expected_output": { "const": "publication_result" },
              "permission_mode": { "const": "full" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "publication_required" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "policy_or_permission_change" },
              "step_id": { "const": "policy_review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "policy_or_permission_change" },
              "step_id": { "const": "apply_policy_change" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "policy_or_permission_change" },
              "step_id": { "const": "final_evidence" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "security_review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "security_review_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "policy_review" },
              "assignment_role": { "const": "approver" },
              "expected_output": { "const": "policy_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "implement" },
              "assignment_role": { "const": "implementer" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "edit" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "qa" },
              "assignment_role": { "const": "qa" },
              "expected_output": { "const": "code_change_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "final_security_review" },
              "assignment_role": { "const": "reviewer" },
              "expected_output": { "const": "security_review_report" },
              "permission_mode": { "const": "readonly" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
            "properties": {
              "workflow_id": { "const": "security_sensitive_change" },
              "step_id": { "const": "publication_gate" },
              "assignment_role": { "const": "publisher" },
              "expected_output": { "const": "publication_result" },
              "permission_mode": { "const": "full" },
              "external_provider_allowed": { "const": false }
            }
          },
          {
