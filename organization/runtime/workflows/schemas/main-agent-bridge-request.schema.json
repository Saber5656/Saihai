{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/main-agent-bridge-request.schema.json",
  "title": "Main Agent Bridge Request",
  "description": "Restricted submit_request payload accepted from the main-agent confirmation surface. Workspace, installed-frontend principal, and checkout identity are bound by the host launcher and cannot be supplied here.",
  "type": "object",
  "required": [
    "task_id",
    "request_id",
    "request_kind",
    "prompt",
    "refs",
    "idempotency_key"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,95}$"
    },
    "request_kind": {
      "type": "string",
      "enum": [
        "agent_task_request",
        "external_review_request",
        "orchestrator_status_request"
      ]
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100000
    },
    "refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      }
    },
    "allowed_paths": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      }
    },
    "expires_at": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "frontdoor": {
      "type": "string",
      "enum": [
        "codex",
        "claude",
        "cursor",
        "grok",
        "manual"
      ]
    },
    "chat_session_id": {
      "type": "string",
      "maxLength": 256
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    }
  },
  "not": {
    "anyOf": [
      {
        "required": [
          "classification"
        ]
      },
      {
        "required": [
          "activation"
        ]
      },
      {
        "required": [
          "workflow_selection"
        ]
      },
      {
        "required": [
          "run_id"
        ]
      },
      {
        "required": [
          "report_path"
        ]
      },
      {
        "required": [
          "principal_type"
        ]
      },
      {
        "required": [
          "principal_id"
        ]
      },
      {
        "required": [
          "authn_method"
        ]
      },
      {
        "required": [
          "owner_principal"
        ]
      },
      {
        "required": [
          "workspace_id"
        ]
      },
      {
        "required": [
          "checkout_identity"
        ]
      },
      {
        "required": [
          "checkout_identity_digest"
        ]
      },
      {
        "required": [
          "launch_session_identity"
        ]
      },
      {
        "required": [
          "launch_session_digest"
        ]
      }
    ]
  },
  "additionalProperties": false
}
