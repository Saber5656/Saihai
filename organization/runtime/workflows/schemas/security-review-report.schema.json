{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saihai.local/schemas/workflows/security-review-report.schema.json",
  "title": "Security Review Report",
  "type": "object",
  "required": [
    "report_version",
    "workflow_id",
    "threat_risk_evidence",
    "security_review",
    "residual_risk",
    "evidence_refs"
  ],
  "properties": {
    "report_version": {
      "const": "1"
    },
    "workflow_id": {
      "const": "security_sensitive_change"
    },
    "threat_risk_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "security_review": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "passed_with_residual_risk",
            "blocked"
          ]
        }
      },
      "additionalProperties": false
    },
    "residual_risk": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
