{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sahai.local/schemas/workflows/provider-adapter-capability.schema.json",
  "title": "Provider Adapter Capability",
  "description": "Capability descriptor for headless CLI and future tmux interactive provider adapters.",
  "type": "object",
  "required": [
    "adapter_contract_version",
    "provider_adapter_id",
    "provider_target",
    "transport",
    "sync_mode",
    "context_freshness",
    "concurrency_unit",
    "permission_enforcement",
    "supports_structured_output",
    "requires_marker",
    "reset_strategy",
    "report_authority",
    "default_model",
    "effective_model_policy"
  ],
  "properties": {
    "adapter_contract_version": {
      "const": "1"
    },
    "provider_adapter_id": {
      "type": "string"
    },
    "provider_target": {
      "type": "string",
      "enum": [
        "claude_headless",
        "codex_cli_openai",
        "hermes_agent",
        "cursor_cli",
        "grok_build_cli"
      ]
    },
    "default_model": {
      "type": "string",
      "minLength": 1
    },
    "effective_model_policy": {
      "type": "string",
      "enum": [
        "required_exact_match",
        "record_without_equality"
      ]
    },
    "transport": {
      "type": "string",
      "enum": [
        "headless_cli",
        "tmux_interactive",
        "codex_exec"
      ]
    },
    "sync_mode": {
      "type": "string",
      "enum": [
        "sync",
        "async",
        "marker_wait",
        "polling"
      ]
    },
    "context_freshness": {
      "type": "string",
      "enum": [
        "fresh_process",
        "persistent_session",
        "requires_reset"
      ]
    },
    "concurrency_unit": {
      "type": "string",
      "enum": [
        "process",
        "pane",
        "session",
        "account",
        "model"
      ]
    },
    "permission_enforcement": {
      "type": "string",
      "enum": [
        "harness",
        "provider",
        "unsupported"
      ]
    },
    "supports_structured_output": {
      "type": "boolean"
    },
    "requires_marker": {
      "type": "boolean"
    },
    "reset_strategy": {
      "type": "string",
      "enum": [
        "none",
        "clear",
        "compact",
        "new_session"
      ]
    },
    "report_authority": {
      "const": "typed_report_and_evidence_file"
    },
    "bridge_pattern": {
      "type": "string",
      "enum": [
        "none",
        "oneshot",
        "mcp"
      ]
    },
    "surface_metadata": {
      "type": "object"
    },
    "command_argv": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "default_timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400
    },
    "max_timeout_seconds": {
      "const": 86400
    },
    "max_context_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "max_output_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "environment_policy": {
      "const": "minimal_allowlist"
    }
  },
  "additionalProperties": false
}
