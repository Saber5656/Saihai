{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-teams-viewer.local/schemas/workflows/publication-result.schema.json",
  "title": "Publication Result",
  "type": "object",
  "required": [
    "result_version",
    "workflow_id",
    "human_approval",
    "attempted_action",
    "result",
    "evidence_refs"
  ],
  "properties": {
    "result_version": {
      "const": "1"
    },
    "workflow_id": {
      "type": "string",
      "enum": [
        "publication_required",
        "security_sensitive_change"
      ]
    },
    "human_approval": {
      "type": "object",
      "required": [
        "approved",
        "source"
      ],
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "source": {
          "const": "human"
        }
      },
      "additionalProperties": false
    },
    "attempted_action": {
      "type": "string",
      "enum": [
        "commit",
        "push",
        "pull_request",
        "none"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "completed",
        "skipped",
        "blocked",
        "failed"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
