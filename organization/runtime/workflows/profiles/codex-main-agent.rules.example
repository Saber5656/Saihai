# Saihai orchestrator-frontend Codex execpolicy rules.
# Verified against codex-cli 0.141.0 and the official Codex Rules manual on
# 2026-07-08.

prefix_rule(
    pattern = ["python3", "scripts/configure_organization.py", "workflow-frontdoor", ["bridge-submit-request", "bridge-read-projection", "bridge-ack-output"]],
    decision = "allow",
    justification = "Main-agent bridge commands are allowed without --state-root; execution-class workflow commands are not.",
    match = [
        "python3 scripts/configure_organization.py workflow-frontdoor bridge-submit-request --request-json request.json",
        "python3 scripts/configure_organization.py workflow-frontdoor bridge-read-projection --request-id req-example",
        "python3 scripts/configure_organization.py workflow-frontdoor bridge-ack-output --request-id req-example",
    ],
    not_match = [
        "python3 scripts/saihai.py frontdoor status --request-id req-example",
        "python3 scripts/saihai.py frontdoor approve --request-id req-example --nonce nonce-example",
        "python3 scripts/configure_organization.py workflow-frontdoor create-run --request-id req-example",
        "python3 scripts/configure_organization.py workflow-frontdoor drain --run-id run-example",
    ],
)

prefix_rule(
    pattern = ["python3", "scripts/configure_organization.py", "workflow-frontdoor", "--state-root", "*", ["bridge-submit-request", "bridge-read-projection", "bridge-ack-output"]],
    decision = "allow",
    justification = "Main-agent bridge commands are allowed with an explicit state root; execution-class workflow commands are not.",
    match = [
        "python3 scripts/configure_organization.py workflow-frontdoor --state-root /tmp/frontdoor-state bridge-submit-request --request-json request.json",
        "python3 scripts/configure_organization.py workflow-frontdoor --state-root /tmp/frontdoor-state bridge-read-projection --request-id req-example",
        "python3 scripts/configure_organization.py workflow-frontdoor --state-root /tmp/frontdoor-state bridge-ack-output --request-id req-example",
    ],
    not_match = [
        "python3 scripts/saihai.py frontdoor status --request-id req-example",
        "python3 scripts/saihai.py frontdoor approve --request-id req-example --nonce nonce-example",
        "python3 scripts/configure_organization.py workflow-frontdoor --state-root /tmp/frontdoor-state create-run --request-id req-example",
        "python3 scripts/configure_organization.py workflow-frontdoor --state-root /tmp/frontdoor-state drain --run-id run-example",
    ],
)
